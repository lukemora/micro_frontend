{
  "name": "mf-vue-demo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "shared-manifest": "node scripts/generate-shared-manifest.js",
    "validate-shared": "node scripts/validate-shared-manifest.js",
    "dev": "pnpm -r --parallel run dev",
    "dev:host": "pnpm --filter host run dev",
    "dev:remote1": "pnpm --filter remote1 run dev",
    "dev:remote2": "pnpm --filter remote2 run dev",
    "dev:remote3": "pnpm --filter remote3 run dev",
    "build": "pnpm -r run build",
    "build:host": "pnpm --filter host run build",
    "build:remote1": "pnpm --filter remote1 run build",
    "build:remote2": "pnpm --filter remote2 run build",
    "build:remote3": "pnpm --filter remote3 run build"
  },
  "devDependencies": {
    "pnpm": "^9.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "vue": "3.4.x",
      "vue-router": "4.2.x",
      "pinia": "2.1.x",
      "element-plus": "2.4.x"
    }
  }
}
